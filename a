// Write a C++ program to print all elements of a matrix in column-wise order.

#include <iostream>
using namespace std;

int main() {
    int r,c,a[10][10];
    cin >> r >> c;
    for(int i=0;i<r;i++)
        for(int j=0;j<c;j++)
            cin >> a[i][j];

    for(int j=0;j<c;j++)
        for(int i=0;i<r;i++)
            cout << a[i][j] << " ";

    return 0;
}